# ============================================================
# .env.example — copy to .env and fill in your values
# For production: set AUTH_DISABLED=false, strong JWT_SECRET
# ============================================================

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://crm:crm_password_here@localhost:5433/crm?schema=public

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO (S3-compatible) ────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345_change_me
S3_BUCKET_RECORDINGS=recordings

# ── Asterisk ARI ─────────────────────────────────────────────
ASTERISK_ARI_URL=http://localhost:8088/ari
ASTERISK_ARI_USER=crm
ASTERISK_ARI_PASS=crm_secret_change_me
ASTERISK_ARI_APP=crm-voice
# Production (PM2): set to 1 so TCP singleton on port 3099 does not fight PM2 restarts
VOICEBOT_DISABLE_SINGLETON=1
# Outbound: milliseconds channel must stay ARI state "Up" before treating as answered (early media).
# VOICEBOT_OUTBOUND_ANSWER_STABLE_MS=700
# Require SIP Ring/Ringing before accepting Up (opt-in; many trunks need it off for ARI). Enable: =1
# VOICEBOT_OUTBOUND_REQUIRE_RING=0
# ARI outbound channel lifetime (seconds) — must cover ring + answer.
# ASTERISK_ARI_ORIGINATE_TIMEOUT_SEC=120
# Zadarma / Stasis: use full SIP URI (matches asterisk dial-out). Auth still via default_outbound_endpoint=trunk-zadarma.
# Якщо не дзвонить: pjsip show registrations + PJSIP_EFAILEDCREDENTIAL → пароль SIP у кабінеті Zadarma.
ASTERISK_OUTBOUND_TRUNK=trunk-zadarma
# Ukraine via Zadarma: international 380… (default). Use national 0… only if your PBX rules require it.
# ZADARMA_OUTBOUND_FORMAT=international
# Dial style: endpoint (default) → PJSIP/<digits>@<trunk> | sip-uri → PJSIP/sip:<digits>@host (if ARI accepts it)
# ASTERISK_OUTBOUND_DIAL_STYLE=endpoint
# ZADARMA_PBX_HOST=pbx.zadarma.com
# Do NOT use ASTERISK_OUTBOUND_ENDPOINT with ${phone} template:
# PM2 dotenv expands ${phone} → empty string at startup, breaking the dial string.
# Ваш віртуальний номер Zadarma або дозволений CLI (інакше провайдер не дасть вихід).
# Не ставте сюди номер абонента.
ASTERISK_OUTBOUND_CALLER_ID=
# Якщо змінюється IP VPS — оновіть also asterisk/config/pjsip.conf
#   external_media_address / external_signaling_address (Docker RTP/SIP).
ASTERISK_MEDIA_ADDRESS=144.124.246.137

# ── Next.js → Gateway proxy (server-side, not exposed to browser) ────────────
GATEWAY_INTERNAL_URL=http://localhost:3010

# ── Internal service URLs ─────────────────────────────────────
CRM_SERVICE_URL=http://localhost:3011
CALLS_SERVICE_URL=http://localhost:3012
PROMPT_SERVICE_URL=http://localhost:3013

# ── TTS service ───────────────────────────────────────────────
TTS_SERVICE_URL=http://localhost:3015
# On VPS: use actual server IP (not host.docker.internal)
TTS_PUBLIC_HOST=http://144.124.246.137:3015

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
AUTH_DISABLED=false
INTERNAL_API_SECRET=CHANGE_ME_INTERNAL_SECRET
CONFIG_MASTER_KEY=CHANGE_ME_32_CHAR_MASTER_KEY

# ── Calls ─────────────────────────────────────────────────────
SIMULATE_CALLS=false
# Outbound VAPI SIP-bridge: off unless explicitly enabled (asterisk-only GPT/TTS by default).
OUTBOUND_USE_VAPI=false

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_VOICE=nova

# ── VAPI ──────────────────────────────────────────────────────
# Architecture: Asterisk dials customer via Zadarma → on answer →
#   Asterisk SIP-bridges to VAPI (sip.vapi.ai) → VAPI AI runs conversation.
# VAPI_SIP_URI: create in VAPI Dashboard → Phone Numbers → + → Provider: VAPI
#   choose your assistant → assign a unique SIP URI like sip:my-bridge@sip.vapi.ai
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_SIP_URI=sip:crm-asterisk-bridge@sip.vapi.ai
# Optional: PJSIP endpoint name in asterisk/config/pjsip.conf (default trunk-vapi).
# Voicebot dials PJSIP/<user>@VAPI_PJSIP_TRUNK — do not use raw sip:… without this trunk.
VAPI_PJSIP_TRUNK=trunk-vapi
VAPI_WEBHOOK_SECRET=
VAPI_MODEL_PROVIDER=openai
VAPI_MODEL_NAME=gpt-4o-mini
VAPI_VOICE_PROVIDER=openai
VAPI_VOICE_ID=nova

# ── Telegram notifications (stop words) ──────────────────────
# Get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Observability ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
